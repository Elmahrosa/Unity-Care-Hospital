# ============================================================
# Unity Care Hospital — Environment Variables
# Copy to backend/.env and fill in real values.
# NEVER commit the real .env file.
# ============================================================

PORT=5000
NODE_ENV=development

# MongoDB URI
MONGODB_URI=mongodb://localhost:27017/unity_care_hospital

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_secure_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_different_secure_random_string
JWT_EXPIRES_IN=1h

# CORS
CORS_ORIGIN=http://localhost:3000

# Optional: ML prediction API
# ML_API_URL=https://your-ml-api.example.com

# Optional: Twilio (emergency dispatch)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
